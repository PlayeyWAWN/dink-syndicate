rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAppOwner() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.lower() == 'benedictramosgarcia@gmail.com';
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    match /userData/{uid}/{document=**} {
      allow read, write: if isAuthenticated() && request.auth.uid == uid;
    }

    match /liveSessions/{token} {
      allow read: if true;
      allow create, update: if isAuthenticated()
        && request.resource.data.sessionId == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.sessionId == request.auth.uid;

      match /viewers/{viewerId} {
        allow read: if true;
        allow create, update: if true;
        allow delete: if true;
      }
    }

    match /appConfig/global {
      allow read: if true;
      allow write: if isAppOwner();
    }

    match /userProfiles/{uid} {
      allow read: if isAppOwner() || (isAuthenticated() && request.auth.uid == uid);
      allow create, update: if isAuthenticated() && request.auth.uid == uid;
      allow delete: if isAppOwner();
    }

    match /adminAnalytics/{rollupId} {
      allow read: if isAppOwner();
      allow create, update: if isAuthenticated();
    }

    match /wallboardAnalytics/{rollupId} {
      allow read: if isAppOwner();
      allow create, update: if isAuthenticated();
    }
  }
}

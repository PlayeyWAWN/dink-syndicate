rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAppOwner() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.lower() == 'benedictramosgarcia@gmail.com';
    }

    match /sponsors/{fileName} {
      allow read: if true;
      allow write: if isAppOwner();
    }
  }
}
